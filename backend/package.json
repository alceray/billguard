{
  "name": "billguard-backend",
  "version": "1.0.0",
  "description": "BillGuard API server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "db:migrate": "node -r tsx/cjs scripts/migrate.ts"
  },
  "dependencies": {
